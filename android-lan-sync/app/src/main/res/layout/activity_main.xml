<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:fillViewport="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
      android:id="@+id/targetHostInput"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:hint="目标主机（PC IP）"
      android:inputType="text"
      android:text="192.168.1.100" />

    <EditText
      android:id="@+id/targetTcpPortInput"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:hint="目标 TCP 端口"
      android:inputType="number"
      android:text="48571" />

    <EditText
      android:id="@+id/discoveryPortInput"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:hint="发现 UDP 端口"
      android:inputType="number"
      android:text="48572" />

    <EditText
      android:id="@+id/listenPortInput"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:hint="本机监听端口（用于收 PairResponse）"
      android:inputType="number"
      android:text="48581" />

    <EditText
      android:id="@+id/deviceNameInput"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:hint="设备名称"
      android:inputType="text"
      android:text="Android LAN Peer" />

    <EditText
      android:id="@+id/textInput"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:hint="同步文本内容"
      android:inputType="textMultiLine"
      android:minLines="3"
      android:text="Hello from Android LAN peer" />

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="12dp"
      android:orientation="horizontal">

      <Button
        android:id="@+id/startListenButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="开始监听" />

      <Button
        android:id="@+id/stopListenButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:text="停止监听" />
    </LinearLayout>

    <Button
      android:id="@+id/heartbeatButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="发送 Heartbeat" />

    <Button
      android:id="@+id/pairRequestButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="发送 PairRequest" />

    <Button
      android:id="@+id/syncTextButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="发送 SyncText" />

    <Button
      android:id="@+id/runAllButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="一键跑全流程" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="12dp"
      android:text="日志"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/logView"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:background="#11000000"
      android:minHeight="180dp"
      android:padding="8dp"
      android:textIsSelectable="true" />
  </LinearLayout>
</ScrollView>
